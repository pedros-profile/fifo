# synthesis.ys
# Complete generic synthesis flow

# 1. Read RTL
read_verilog -sv ../fifo.sv

# 2. Elaborate hierarchy
hierarchy -check -top fifo

# 3. High-level synthesis
proc          # Convert behavioral to structural
fsm           # Optimize FSMs
opt_clean

# Add the Python script from 
# https://stackoverflow.com/questions/32645965/fsm-export-using-yosys
# to export the infered FSM diagram
# fsm -nomap
# fsm_export -o fsm.kiss2
# !python kiss2dot.py fsm.kiss2 > fsm.dot

memory        # Handle memories

# 4. Optimize
opt           # First optimization pass
opt           # Second pass (often finds more)

# 5. Generate visual output
show -prefix generic_netlist -format svg

# 6. Statistics
stat

# 7. Write output
write_verilog -noattr generic_netlist.v
